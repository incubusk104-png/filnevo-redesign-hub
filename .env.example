# Supabase — when set, the console enforces auth (login) + reads live data via RLS.
# When unset, the dashboard runs in DEMO mode on simulated data with no auth gate.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side Supabase (used by API route factories in production mode).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Service-role key — used ONLY by server-side admin routes (/api/admin/*) to
# read/write across tenants (bypasses RLS). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Google sign-in (OAuth) needs NO app env vars — enable the Google provider in
# the Supabase dashboard (Authentication -> Providers) and add ${APP_URL}/auth/
# callback to the redirect allow-list. See docs/ADMIN_SETUP.md §9.

# AI providers (routing: free tier -> Cerebras, paid tiers -> OpenAI).
# Keep real keys out of the repo — set these in your deployment env only.
CEREBRAS_API_KEY=
OPENAI_API_KEY=

# 21st.dev agent token endpoint key.
API_KEY_21ST=

# Billing — PayMongo (PH, QR Ph only: pay via GCash / Maya / InstaPay bank apps).
# When PAYMONGO_SECRET_KEY is unset, billing runs in DEMO mode: /api/billing/qrph
# returns a stubbed placeholder QR and the webhook skips signature verification,
# so the flow works without keys.
PAYMONGO_SECRET_KEY=
# Webhook signing secret (PayMongo dashboard -> Developers -> Webhooks). Used to
# verify the Paymongo-Signature HMAC on /api/billing/webhook.
PAYMONGO_WEBHOOK_SECRET=
# Public base URL used for auth (OAuth / email-confirmation) callbacks. SET THIS
# to your live domain in production (e.g. https://filnevo.pages.dev). If unset in
# production, the app falls back to the request's host header, but an explicit
# value is preferred.
APP_URL=http://localhost:3000
